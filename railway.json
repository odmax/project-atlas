{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "composer install --ignore-platform-reqs && npm install && npm run build"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "NEVER",
    "startCommand": "php artisan serve --host=0.0.0.0 --port=$PORT"
  }
}